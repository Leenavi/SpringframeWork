<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.simplane.mapper.BoardMapper">

    <resultMap id="BoardResultMap" type="com.simplane.domain.BoardVO">
        <id property="boardid" column="boardid"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="imagePath" column="imagepath"/>
        <result property="regDate" column="regdate"/>
    </resultMap>

    <select id="read" resultMap="BoardResultMap">
        SELECT * FROM sim_board WHERE boardid = #{boardid}
    </select>

    <select id="readAll" resultMap="BoardResultMap">
        select * from sim_board where boardid > 0
    </select>




</mapper>